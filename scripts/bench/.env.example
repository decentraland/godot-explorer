# GP benchmark environment (issue #1862).
#
# Anything host-, network-, or identity-specific lives here so the tracked
# scripts and docs stay clean. Add new vars to this file rather than
# hardcoding in scripts/.
#
# Copy to scripts/bench/.env (gitignored) and fill in your values.
# launch_devices.sh sources scripts/bench/.env when present.
# For desktop xcodebuild calls, source the file once per shell:
#   set -a; source scripts/bench/.env; set +a

# IP/host of your dev box reachable from the phones (Tailscale, LAN, or whatever).
# This is where `npx @dcl/sdk-commands start` is running.
PREVIEW_HOST=http://192.168.1.10:8000

# iOS signing team for xcodebuild. Ask the project lead.
DEVELOPMENT_TEAM=

# Optional: override which iPhone to target (default: first paired device).
# Find with `xcrun devicectl list devices`.
#IOS_UDID=

# Optional: respected by adb when multiple Android devices are connected.
#ANDROID_SERIAL=
