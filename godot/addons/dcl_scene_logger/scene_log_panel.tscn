[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/dcl_scene_logger/scene_log_panel.gd" id="1"]

[node name="SceneLogPanel" type="HSplitContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
split_offset = 350
script = ExtResource("1")

[node name="LeftPanel" type="VBoxContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3
size_flags_stretch_ratio = 1.0

[node name="Toolbar" type="HBoxContainer" parent="LeftPanel"]
layout_mode = 2

[node name="FilterEdit" type="LineEdit" parent="LeftPanel/Toolbar"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Filter entities..."

[node name="CheckPause" type="CheckButton" parent="LeftPanel/Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Pause"

[node name="ButtonClear" type="Button" parent="LeftPanel/Toolbar"]
layout_mode = 2
text = "Clear"

[node name="LabelCount" type="Label" parent="LeftPanel/Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "0 entities"

[node name="EntityTree" type="Tree" parent="LeftPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
columns = 2
column_titles_visible = true
hide_root = true
allow_reselect = true

[node name="RightPanel" type="VBoxContainer" parent="."]
layout_mode = 2
size_flags_horizontal = 3
size_flags_stretch_ratio = 1.0

[node name="EntityInfoLabel" type="Label" parent="RightPanel"]
unique_name_in_owner = true
layout_mode = 2
text = "Select an entity"

[node name="ComponentsLabel" type="Label" parent="RightPanel"]
layout_mode = 2
text = "Components"
horizontal_alignment = 1

[node name="ComponentsTree" type="Tree" parent="RightPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
size_flags_stretch_ratio = 1.0
columns = 2
column_titles_visible = true
hide_root = true

[node name="ChangesLabel" type="Label" parent="RightPanel"]
layout_mode = 2
text = "Live Changes"
horizontal_alignment = 1

[node name="ChangesList" type="ItemList" parent="RightPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
size_flags_stretch_ratio = 1.0
auto_height = false

[connection signal="pressed" from="LeftPanel/Toolbar/ButtonClear" to="." method="_on_button_clear_pressed"]
[connection signal="text_changed" from="LeftPanel/Toolbar/FilterEdit" to="." method="_on_filter_changed"]
[connection signal="toggled" from="LeftPanel/Toolbar/CheckPause" to="." method="_on_pause_toggled"]
[connection signal="item_selected" from="LeftPanel/EntityTree" to="." method="_on_tree_item_selected"]
