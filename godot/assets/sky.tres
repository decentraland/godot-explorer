; tint_color_cycle_bottom (zenith tint): multiplies sky base. Cycle = skybox_time + 0.43,
; so cycle 0.43=midnight, 0.93=noon, 0.23=sunset, 0.63=sunrise. Keep white at midnight/noon
; (let base color show), warm at sunrise/sunset.
[sub_resource type="Gradient" id="Gradient_dn7ne"]
interpolation_mode = 2
interpolation_color_space = 2
offsets = PackedFloat32Array(0.0, 0.13, 0.23, 0.43, 0.63, 0.83, 1.0)
colors = PackedColorArray(0.95, 0.95, 0.95, 1, 0.95, 0.92, 0.9, 1, 1.0, 0.7, 0.5, 1, 0.85, 0.85, 0.95, 1, 1.0, 0.7, 0.5, 1, 0.95, 0.92, 0.9, 1, 0.95, 0.95, 0.95, 1)

