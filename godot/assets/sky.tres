; sky_gradient: base sky color sampled by day_night_blend (0=noon, 1=midnight).
; Day color: tonemap+glow brighten midtones, so input must be lower than output target.
; Targeted Unity U12 sky avg (126,178,197). Reduced B significantly (was 0.73, now 0.55)
; because Godot pipeline was over-amplifying blue.
[sub_resource type="Gradient" id="Gradient_8yx6h"]
offsets = PackedFloat32Array(0.0, 1.0)
colors = PackedColorArray(0.39, 0.6, 0.55, 1, 0.15, 0.03, 0.4, 1)

[sub_resource type="GradientTexture1D" id="GradientTexture1D_8513b"]
gradient = SubResource("Gradient_8yx6h")
width = 3

